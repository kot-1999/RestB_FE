doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title RestBoo - Restaurant Booking
    link(rel="stylesheet", href="./css/styles.css")
    script(src='https://code.jquery.com/jquery-3.7.1.min.js')
    script(src='https://cdn.jsdelivr.net/npm/chart.js')

  body
    nav
      include pages/components/nav

    content#content
      include pages/home

    div(style="display:none")
      template#auth-template
        include pages/auth
    div(style="display:none")
      template#profile-template
        include pages/profile
    div(style="display:none")
      template#home-template
        include pages/home
    div(style="display:none")
      template#restaurant-details-template
        include pages/restaurantDetails
    div(style="display:none")
      template#dashboard-template
        include pages/dashboard
    div(style="display:none")
      template#login-component-template
        include pages/components/authForms/login
    div(style="display:none")
      template#register-component-template
        include pages/components/authForms/register
    div(style="display:none")
      template#forgot-password-component-template
        include pages/components/authForms/forgotPassword
    div(style="display:none")
      template#restaurant-card-template
        include pages/components/restaurantCard
    div(style="display:none")
      template#dummy-profile-template
        include pages/components/profileCard
    div(style="display:none")
      template#reset-password-template
        include pages/resetPassword
    div(style="display:none")
      template#register-employee-template
        include pages/registerEmployee
    div(style="display:none")
      template#mybooking-template
            include pages/bookings
    div(style="display:none")
      template#admin-restaurants-template
            include pages/adminrestaurants
    div(style="display:none")
      template#bookings-manage
        include pages/bookingsManage
    div(style="display:none")
      template#booking-card-template
        include pages/components/bookingCard
    div(style="display:none")
      template#brand-card-template
        include pages/components/brandCard
    div(style="display:none")
      template#restaurant-booking-card-template
        include pages/components/restaurantBookingCard

    div(style="display:none")
      template#pagination-template
        include pages/components/pagination

    script(src='https://cdn.jsdelivr.net/npm/sweetalert2@11')
    script(type="module" src="./js/main.js")
