head
  meta(charset="UTF-8")
  meta(name="viewport", content="width=device-width, initial-scale=1.0")
  title RestBoo - Restaurant Booking

  // Styles
  link(rel="stylesheet" href="/css/styles.css")

  // jQuery — must come BEFORE any script that uses it
  script(src="https://code.jquery.com/jquery-3.7.1.min.js")

body
  nav
    include pages/components/nav

  content#content
    include pages/home

  // Templates hidden
  div(style="display:none")
    template#auth-template
      include pages/auth
    template#profile-template
      include pages/profile
    template#home-template
      include pages/home
    template#restaurant-details-template
      include pages/restaurantDetails
    template#dashboard-template
      include pages/dashboard
    template#login-component-template
      include pages/components/authForms/login
    template#register-component-template
      include pages/components/authForms/register
    template#restaurant-card-template
      include pages/components/restaurantCard
    template#dummy-profile-template
      include pages/components/dummyProfileTemplate
    template#mybooking-template
      include pages/mybooking
    template#admin-restaurants-template
      include pages/adminrestaurants
  template#reset-password-component-template
      include pages/components/authForms/resetPassword

  // Scripts
  // 1. SweetAlert
  script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

  // 2. Any non-module scripts that rely on jQuery
  script(src="/js/pages/auth.js")  

  // 3. Main module script (type="module")
  script(type="module" src="/js/main.js")