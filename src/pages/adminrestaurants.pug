#admin-restaurants-root
    .ar-container
        .ar-header
            h1 Admin: Manage Restaurants
            p.ar-subtitle
                | Edit restaurant details, hours, categories, cover image,
                |  and gallery photos.

        .ar-toolbar
            button#ar-new-btn(type="button") Create New Restaurant

        #restaurants-container

        #restaurants-empty(hidden)
            .ar-empty-state
                h2 No restaurants yet
                p Start by creating your first restaurant listing.
                button#ar-empty-create-btn(type="button") Create New Restaurant

    template#restaurant-card-template
        .ar-card(data-id="{{id}}")
            .ar-card-header
                .ar-card-title-wrap
                    h2.ar-name(contenteditable="true" spellcheck="false") {{name}}
                    span.ar-card-chip {{status}}
                button.ar-remove-btn(type="button") Remove Restaurant

            .ar-card-section
                .ar-field
                    label(for="ar-autoapprove-{{id}}") Auto-approve max guests
                    input.ar-autoapprove(
                        id="ar-autoapprove-{{id}}"
                        type="number"
                        min="0"
                        value="{{autoApprove}}"
                        placeholder="Enter guest limit"
                    )

                .ar-field
                    label(for="ar-types-{{id}}") Restaurant types
                    input.ar-types(
                        id="ar-types-{{id}}"
                        type="text"
                        value="{{types}}"
                        placeholder="e.g. Italian, Fine Dining, Rooftop"
                    )

                .ar-field
                    label(for="ar-address-{{id}}") Address
                    input.ar-address(
                        id="ar-address-{{id}}"
                        type="text"
                        value="{{address}}"
                        placeholder="Building, street, city, postcode, country"
                    )

            .ar-card-section
                .ar-field
                    label(for="ar-opening-{{id}}") Opening time
                    input.ar-opening(
                        id="ar-opening-{{id}}"
                        type="time"
                        value="{{opening}}"
                    )

                .ar-field
                    label(for="ar-closing-{{id}}") Closing time
                    input.ar-closing(
                        id="ar-closing-{{id}}"
                        type="time"
                        value="{{closing}}"
                    )

            .ar-field
                label(for="ar-description-{{id}}") Description
                textarea.ar-description(
                    id="ar-description-{{id}}"
                    rows="4"
                    placeholder="Write a short restaurant description"
                ) {{description}}

            .ar-field.ar-cover-field
                .ar-media-header
                    label Cover image
                    span.ar-media-hint Main restaurant photo

                .ar-cover-dropzone
                    span Drag & drop a cover image here or click to upload
                    input.ar-cover-input(
                        type="file"
                        accept="image/*"
                    )

                .ar-cover-preview

            .ar-field.ar-gallery-field
                .ar-gallery-header
                    label Gallery images
                    span.ar-gallery-count 0 images

                .ar-gallery-dropzone
                    span Drag & drop gallery images here or click to upload
                    input.ar-gallery-input(
                        type="file"
                        accept="image/*"
                        multiple
                    )

                .ar-gallery-preview

            .ar-card-actions
                button.ar-submit-btn(type="button") Save Changes

    .ar-lightbox-overlay
        button.ar-lightbox-close(type="button" aria-label="Close image preview") ×
        img(src="" alt="Full-size restaurant image")