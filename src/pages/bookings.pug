div.dashboard-page
  .dashboard-wrap
    .dash-header
      .dash-title
        h1#dashboardTitle Bookings for <span style="color:var(--text-main)" id="restaurant-name"></span>
        p#dashboardSub Today's mission control overview.
      .dash-brand
        .dash-brand-field
          label(for="brand") Brand name
          select#brand(name="brand")
            // Options will be dynamically loaded by JS
            option(value="La Benetti" selected) La Benetti
            option(value="Independent") Independent
            option(value="Chain") Chain
        .dash-avatar(title="Admin")
          img(src="/assets/img/default-avatar.png" alt="Admin avatar")

    .container.py-5
      .row.mb-4
        .col-md-12
          .filter-bar.p-3.rounded.booking-filter-bar
            // Filter elements will go here
            p.text-white Filters (Coming Soon)

      .bookings-grid#bookings-list
        // Booking cards will be rendered here by JavaScript
