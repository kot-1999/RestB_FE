//- resetPassword.pug
div.reset-password-page
    .rp-container
        h1 Reset Your Password
        p Enter your new password below.

        form#resetPasswordForm
            label(for="newPassword") New Password
            input#newPassword(type="password" placeholder="New password" required)

            label(for="confirmPassword") Confirm Password
            input#confirmPassword(type="password" placeholder="Confirm password" required)

            button(type="submit") Reset Password

        #rp-message(style="display:none") 
            | Password updated successfully!