.booking-card(data-id="{{id}}" data-status="{{status}}")

    //── HEADER: name, ref, status pill ───────────────────────────────────
    .bc-header
        .bc-header-left
            span.bc-status-dot(class="status-{{status}}")
            div
                h2.bc-name
                    | {{#restaurantID}}
                    a(href="#restaurant-details?id={{restaurantID}}") {{customerName}}
                    | {{/restaurantID}}
                    | {{^restaurantID}}
                    | {{customerName}}
                    | {{/restaurantID}}
                span.bc-ref \#{{id}}
        span.bc-status-pill(class="status-pill-{{status}}") {{status}}

    // ── META: date / time / guests / contact ─────────────────────────────
    .bc-meta
        div.bc-meta-row
            .bc-meta-item
                i.fas.fa-calendar-alt
                span Date: {{formattedDate}}
            .bc-meta-item
                i.fas.fa-clock
                span Time: {{formattedStartTime}}
            .bc-meta-item
                i.fas.fa-users
                span Guests: {{numGuests}}
        div.booking-card-meta.bc-meta-row.trackable
            .bc-meta-item
                i.fas.fa-envelope
                span Guest details: {{customerEmail}}
            .bc-meta-item
                i.fas.fa-phone
                span {{customerPhone}}

    // ── CHAT ─────────────────────────────────────────────────────────────
    .bc-chat
        .bc-chat-messages
        .bc-chat-input-row
            input.bc-chat-input(type="text" placeholder="Type a message… send with a status button below")
            button.bc-chat-send.js-chat-send(title="Queue message") &#9658;

    // ── ACTIONS ──────────────────────────────────────────────────────────
    .bc-actions
        button.booking-card-approve.bc-btn.bc-btn-confirm.js-action(data-status="Approved").trackable CONFIRM
        button.booking-card-cancel.bc-btn.bc-btn-decline.js-action(data-status="Cancelled") CANCEL
        button.booking-card-confirm.bc-btn.bc-btn-complete.js-action(data-status="Completed").trackable COMPLETE
        button.booking-card-noshow.bc-btn.bc-btn-noshow.js-action(data-status="NoShow").trackable NO SHOW