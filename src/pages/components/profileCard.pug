form#updateProfileForm
    h2 Wellcome back
    div.avatar-section
        img#userAvatar(src="{{user.avatarURL}}{{admin.avatarURL}}" width="200")
        input(type="file" name="avatar" accept="image/*")

    div.form-fields

        div.field-group
            label First Name
            input(type="text" name="firstName" value="{{user.firstName}}{{admin.firstName}}" required minlength="3" maxlength="255")

        div.field-group
            label Last Name
            input(type="text" name="lastName" value="{{user.lastName}}{{admin.lastName}}" required minlength="3" maxlength="255")

        div.field-group
            label Email
            input(type="email" name="email" value="{{user.email}}{{admin.email}}" required)

        div.field-group
            label Phone Number
            input(type="text" name="phone" value="{{user.phone}}{{admin.phone}}" required)

        div#profile-role.field-group.trackable
            label Role
            input(type="text" name="role" value="{{admin.role}}" readonly)

    div.profile-actions(style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;")
        button(type="submit" style="background: #facc15; color: #000; border: none; padding: 10px; border-radius: 4px; cursor: pointer; font-weight: bold;") Update Profile
        button.btn-delete-profile(type="button" style="background: transparent; border: 1px solid #ff4d4d; color: #ff4d4d; padding: 10px; border-radius: 4px; cursor: pointer; font-weight: bold;") Delete Profile