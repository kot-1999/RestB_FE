a.restaurant-card(href="/restaurants/{{_id}}")
    .restaurant-banner
        img(src="{{bannerURL}}" alt="{{name}}")
        .restaurant-overlay
            span.restaurant-cta {{ctaLabel}}

    .restaurant-content
        h3.restaurant-name {{name}}

        .restaurant-tags
            span.restaurant-tag {{restaurantType}}
            | {{#isLate}}
            span.restaurant-tag.restaurant-tag--late 🍸 Late Bar
            | {{/isLate}}

        .restaurant-meta
            span.restaurant-status(class="{{statusClass}}") {{statusLabel}}

        p.restaurant-description {{description}}

        .restaurant-brand
            img.brand-logo(src="{{brand.logoURL}}" alt="{{brand.name}}")
            .restaurant-brand-text
                span.restaurant-brand-label Brand
                span.brand-name {{brand.name}}

        .restaurant-details
            .restaurant-detail-row
                span.detail-label City
                span.detail-value {{address.city}}

            .restaurant-detail-row
                span.detail-label Address
                span.detail-value {{address.building}} {{address.street}}

            .restaurant-detail-row
                span.detail-label Postcode
                span.detail-value {{address.postcode}}