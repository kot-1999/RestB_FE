div.dashboard-page
    .dashboard-wrap
        div#brand-admin-header.trackable

        // ===== KPI cards =====
        .dash-kpis
            .kpi
                p.kpi-label Total bookings
                p.kpi-value 0
                p.kpi-meta#totalBookingsMeta This week
            .kpi
                p.kpi-label Pending bookings
                p.kpi-value 0
                p.kpi-meta Needs review
            .kpi
                p.kpi-label Cancelled
                p.kpi-value 0
                p.kpi-meta#cancelledMeta This week
            .kpi
                p.kpi-label People booked
                p.kpi-value 0
                p.kpi-meta#guestsMeta Covers (guests)

        // ===== Chart card =====
        .dash-card
            .dash-card-head
                h2#chartTitle Weekly bookings
                .dash-card-actions
                    button.dash-chip.is-active(type="button") Past 7 days
                    button.dash-chip(type="button") Past 30 days
            .dash-chart
                canvas#bookingsChart(width="400" height="400")

        // ===== Filters row =====
        .dash-filters
            .filter-row
                div#dashboard-restaurant-filter.filter-group.trackable
                    label Restaurant:
                    .check-row#restaurantFilter
                        // Dynamically populated by JS
                .filter-group
                    label Show Only:
                    .check-row
                        label.check
                            input(type="checkbox" name="showOnly" value="approved" checked)
                            span Approved Bookings
                        label.check
                            input(type="checkbox" name="showOnly" value="pending" checked)
                            span Pending Bookings
                        label.check
                            input(type="checkbox" name="showOnly" value="cancelledAdmin")
                            span Canceled by Admin
                        label.check
                            input(type="checkbox" name="showOnly" value="cancelledUser")
                            span Canceled by User