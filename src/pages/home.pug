section.dashboard-page.home-page
    .home-filter-bar
        .home-filter-bar-inner
            .home-brand
                h1 RestBoo
                p.home-sidebar-copy Find the right restaurant for your date, location, and party size — then book in a few clicks.

            form.home-filters.js-home-filters
                .home-filter-row.home-filter-row--top
                    .home-filter-group.is-search
                        label.home-filter-label(for="restaurant-search") Search
                        input#restaurant-search.home-input.js-filter-search(
                            type="text"
                            placeholder="Where? e.g. London Bridge"
                        )

                    .home-filter-group.is-radius
                        label.home-filter-label(for="restaurant-radius") Radius
                        .home-range-wrap
                            input#restaurant-radius.home-range.js-filter-radius(
                                type="range"
                                min="1"
                                max="100"
                                step="5"
                                value="20"
                            )
                            span.home-range-badge.js-radius-value 20 km

                .home-filter-row.home-filter-row--bottom
                    .home-filter-group
                        label.home-filter-label(for="restaurant-date") Date
                        input#restaurant-date.home-input.js-filter-date(
                            type="date"
                        )

                    .home-filter-group
                        label.home-filter-label(for="restaurant-guests") Guests
                        input#restaurant-guests.home-input.js-filter-guests(
                            type="number"
                            min="1"
                            max="20"
                            value="2"
                            placeholder="Guests"
                        )

                    .home-filter-group
                        label.home-filter-label(for="restaurant-category") Category
                        input#restaurant-category.home-input.js-category-input(
                            type="text"
                            list="restaurant-category-options"
                            placeholder="Type to add category"
                            autocomplete="off"
                        )
                        datalist#restaurant-category-options.js-category-datalist

                    .home-filter-actions
                        button.home-submit-btn(type="submit") Search

            .home-category-selected.js-selected-categories#selected-categories

    .home-main
        .dash-card
            .dash-card-head
                h2 Browse Restaurants
                .dash-card-actions
                    span.dash-chip.is-active Amount
                    span.dash-chip.js-restaurant-count 0

            .restaurants-loading(style="display: none;")
                .skeleton-grid
                    each _ in [1, 2, 3]
                        .skeleton-card
                            .skeleton-banner
                            .skeleton-content
                                .skeleton-line.title
                                .skeleton-line.desc
                                .skeleton-line.meta

            .restaurants-container

    div#pagination