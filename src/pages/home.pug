// ===================================
// HOME PAGE
// ===================================

.section-wrapper

  // HERO SECTION
  section.rest-hero
    .container
      h1.page-title Find & Book Your Perfect Table
      p.page-subtitle
        | Discover top-rated restaurants and make instant reservations
        | with a seamless booking experience.

  // FILTER BAR
  section.rest-filters
    .container.filters-container
      .filters-inner
        // Availability
        .filter-group
          label(for="availableNow") Availability
          .checkbox-row
            input#availableNow(type="checkbox" name="availableNow")
            span Available Now

        // Date
        .filter-group
          label(for="date") Date
          input#date(type="date" name="date")

        // Type
        .filter-group
          label(for="type") Type
          select#type(name="type")
            option(value="") All Types
            option(value="italian") Italian
            option(value="japanese") Japanese
            option(value="indian") Indian
            option(value="mexican") Mexican
            option(value="steakhouse") Steakhouse
            option(value="thai") Thai
            option(value="vegan") Vegan
            option(value="seafood") Seafood
            option(value="brunch") Brunch

        // Guests
        .filter-group
          label(for="guests") Guests
          select#guests(name="guests")
            option(value="") Any
            option(value="1") 1 Person
            option(value="2") 2 People
            option(value="3") 3 People
            option(value="4") 4 People
            option(value="5") 5 People
            option(value="6") 6 People
            option(value="7") 7 People
            option(value="8") 8+ People

  // RESULTS SECTION
  section.rest-results
    .container
      p#results-count.meta Showing available restaurants

