  .mb-container

    // Header
    .mb-header
      h1 Admin Bookings
      p.mb-subtitle Manage and review restaurant reservations.

    // Top Tabs (Upcoming / Past)
    .mb-tabs
      .mb-tabs-inner
        button.mb-tab.active(type="button", data-filter="upcoming") Upcoming
        button.mb-tab(type="button", data-filter="past") Past
        .mb-tab-indicator

    // Status Filter Tabs
    .mb-status-tabs
      .mb-tabs-inner
        button.mb-status-tab.active(type="button", data-status="all") All
        button.mb-status-tab(type="button", data-status="confirmed") Confirmed
        button.mb-status-tab(type="button", data-status="pending") Pending
        button.mb-status-tab(type="button", data-status="cancelled") Cancelled
        .mb-tab-indicator

    // Search
    .mb-search
      input(type="search", placeholder="Search restaurant or customer...")

    // Bookings List
    #bookings-container.mb-list

    // Empty State
    #bookings-empty.mb-empty(hidden)
      h2 No bookings found

    // Cancel Confirmation Modal
    #cancelModal.mb-modal
      .mb-modal-backdrop
      .mb-modal-content
        h3 Cancel Booking?
        p This action cannot be undone.
        .mb-modal-actions
          button.mb-modal-cancel(type="button") Keep
          button.mb-modal-confirm(type="button") Confirm Booking Cancellation

    // User Details Modal
    #userModal.mb-modal
      .mb-modal-backdrop
      .mb-modal-content
        h3 Customer Details
        .mb-user-modal-body
          p
            strong Name:
            span#modalUserName
          p
            strong Email:
            span#modalUserEmail
          p
            strong Phone:
            span#modalUserPhone
        .mb-modal-actions
          button#closeUserModal.mb-modal-cancel(type="button") Close

    // Mustache Template for booking cards
