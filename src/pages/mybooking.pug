//- mybooking.pug
//- Bookings management page - shows all bookings with their statuses

main.mybookings-page

  //- Filter bar
  .bk-filter
    label Status:
    select
      option(value='') All
      option(value='Approved') Approved
      option(value='Pending') Pending
      option(value='Cancelled') Cancelled
    label From:
    input(type='date')
    label To:
    input(type='date')

  //-
    ─────────────────────────────────────────
    CARD 1 — Cancelled by Manager
    ─────────────────────────────────────────
  .bk-card
    img.bk-restaurant-img(src='https://picsum.photos/seed/rest1/800/200' alt='Restaurant photo')
    .bk-fields
      .bk-field
        span.bk-label Date
        input.bk-input(type='text' value='19/03/2026' readonly)
      .bk-field
        span.bk-label Time
        input.bk-input(type='text' value='19:00' readonly)
      .bk-field
        span.bk-label Number of people
        input.bk-input(type='text' value='3' readonly)
      .bk-field
        span.bk-label Restaurant
        input.bk-input(type='text' value='Pizza/Pasta' readonly)
      .bk-field.bk-span2
        span.bk-label Location
        input.bk-input(type='text' value='UK, London, Haydons rd 123' readonly)
      .bk-field
        span.bk-label Phone
        input.bk-input(type='text' value='+123123123123' readonly)
      .bk-field.bk-span2
        span.bk-label Email
        input.bk-input(type='text' value='user@user.com' readonly)

    hr.bk-divider

    .bk-messages
      .bk-msg
        .bk-avatar-placeholder U
        .bk-bubble
          strong User:
          | Can we have seats by the window
      .bk-msg.manager
        .bk-avatar-placeholder M
        .bk-bubble
          strong Emanuel Versodi:
          | Our apologies, we don't have enough space on that day

    .bk-actions
      span.bk-badge.cancelled-manager Cancelled by Manager

  //-
    ─────────────────────────────────────────
    CARD 2 — Approved
    ─────────────────────────────────────────
  .bk-card
    img.bk-restaurant-img(src='https://picsum.photos/seed/rest1/800/200' alt='Restaurant photo')
