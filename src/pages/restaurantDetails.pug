div.restaurant-book-page
    //- ── TOP HEADER ─────────────────────────────────────────────────────
    header.rb-page-header
        h1#rb-name.rb-banner-title Loading restaurant...
        p#rb-desc.rb-description Please wait while we fetch the restaurant details.

    //- ── MAIN CONTENT ───────────────────────────────────────────────────
    section.rb-content-wrapper
        //- ── LEFT: BOOKING CARD ────────────────────────────────────────
        aside.rb-sticky-left
            #booking-details-create-form.rb-panel.rb-booking.trackable
                h2 Book Here

                .rb-row
                    .rb-field
                        label(for="rb-date") Date
                        input#rb-date(type="date")

                    .rb-field
                        label(for="rb-guests") Number of people
                        input#rb-guests(
                            type="number"
                            min="1"
                            max="20"
                            value="2"
                        )

                .rb-row
                    .rb-field
                        label(for="rb-time") Start time
                        input#rb-time(
                            type="time"
                            value="19:00"
                        )

                .rb-field
                    label(for="rb-message") Message
                    textarea#rb-message(
                        rows="4"
                        placeholder="Any special request for the restaurant?"
                    )

                .rb-booking-actions
                    button#rb-confirm.rb-btn(
                        type="button"
                        disabled
                    ) Confirm Booking
                    p#rb-msg.rb-msg

        //- ── RIGHT: DETAILS / IMAGE / GALLERY / REVIEWS ───────────────
        section.rb-main-flow
            .rb-top-row
                .rb-panel.rb-details
                    h3 Information

                    .rb-info
                        p
                            strong Brand:
                            span#rb-brand Loading...

                        p
                            strong Location:
                            span#rb-location Loading...

                        p
                            strong Categories:
                            span#rb-categories Loading...

                        p
                            strong Opening times:
                            span#rb-hours Loading...

                .rb-image-container
                    img#rb-banner.rb-banner-img(
                        src="/assets/img/restaurant2.jpg"
                        alt="Restaurant banner"
                    )

            .rb-scroll-area
                //- ── GALLERY ───────────────────────────────────────────
                section.rb-gallery
                    .rb-section-title
                        h2 Gallery
                        p A little peek before you book.

                    .rb-gallery-grid#rb-gallery-grid
                        a.rb-shot(href="#")
                            img(
                                src="/assets/img/restaurant2.jpg"
                                alt="Loading gallery image"
                            )

                //- ── REVIEWS (mock, kept intentionally) ───────────────
                section.rb-reviews
                    .rb-section-title
                        h2 Reviews
                        p Recent feedback from diners.

                    .rb-review-list
                        article.rb-review
                            .rb-review-top
                                strong Aoife
                                span.rb-stars ★★★★★
                            p.rb-review-text “Amazing food and super friendly staff — will definitely be back.”

                        article.rb-review
                            .rb-review-top
                                strong Liam
                                span.rb-stars ★★★★☆
                            p.rb-review-text “Great vibe, quick service. Portions were solid.”

                        article.rb-review
                            .rb-review-top
                                strong Emma
                                span.rb-stars ★★★★☆
                            p.rb-review-text “Really nice place for a casual dinner — the ramen was unreal.”